APP_TAG=1.8.1
NODE_ENV=production

# –––––––––––––––––––––––––––––––––––––––––
# URL e porta
# –––––––––––––––––––––––––––––––––––––––––

URL=https://docs.example.com
EXPOSE_PORT=3000
PORT=3000
WEB_CONCURRENCY=15

# –––––––––––––––––––––––––––––––––––––––––
# Chiavi crittografiche (generate dall'installer)
# –––––––––––––––––––––––––––––––––––––––––

SECRET_KEY=
UTILS_SECRET=

DEFAULT_LANGUAGE=en_US

# –––––––––––––––––––––––––––––––––––––––––
# Database
# –––––––––––––––––––––––––––––––––––––––––

DATABASE_URL=postgres://user:pass@postgres:5432/outline
DATABASE_CONNECTION_POOL_MIN=
DATABASE_CONNECTION_POOL_MAX=
PGSSLMODE=disable

# –––––––––––––––––––––––––––––––––––––––––
# Redis
# –––––––––––––––––––––––––––––––––––––––––

REDIS_URL=redis://redis:6379

# –––––––––––––––––––––––––––––––––––––––––
# Storage file
# –––––––––––––––––––––––––––––––––––––––––

FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000
FILE_STORAGE_IMPORT_MAX_SIZE=
FILE_STORAGE_WORKSPACE_IMPORT_MAX_SIZE=

# –––––––––––––––––––––––––––––––––––––––––
# SSL / Reverse proxy
# –––––––––––––––––––––––––––––––––––––––––

FORCE_HTTPS=false
PROXY_IP_HEADER=

# –––––––––––––––––––––––––––––––––––––––––
# Autenticazione — Slack
# –––––––––––––––––––––––––––––––––––––––––

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# –––––––––––––––––––––––––––––––––––––––––
# Autenticazione — Google
# –––––––––––––––––––––––––––––––––––––––––

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# –––––––––––––––––––––––––––––––––––––––––
# Autenticazione — Microsoft Entra / Azure AD
# –––––––––––––––––––––––––––––––––––––––––

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_RESOURCE_APP_ID=

# –––––––––––––––––––––––––––––––––––––––––
# Autenticazione — Discord
# –––––––––––––––––––––––––––––––––––––––––

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_SERVER_ID=

# –––––––––––––––––––––––––––––––––––––––––
# Autenticazione — OIDC generico (es. Authentik)
# –––––––––––––––––––––––––––––––––––––––––

OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTH_URI=
OIDC_TOKEN_URI=
OIDC_USERINFO_URI=
OIDC_LOGOUT_URI=
OIDC_USERNAME_CLAIM=preferred_username
OIDC_DISPLAY_NAME=OpenID Connect
OIDC_SCOPES=openid profile email

# –––––––––––––––––––––––––––––––––––––––––
# SMTP
# –––––––––––––––––––––––––––––––––––––––––

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=Docs <noreply@example.com>
SMTP_SECURE=true
SMTP_NAME=SMTP

# –––––––––––––––––––––––––––––––––––––––––
# Rate limiter
# –––––––––––––––––––––––––––––––––––––––––

RATE_LIMITER_ENABLED=true
RATE_LIMITER_REQUESTS=1000
RATE_LIMITER_DURATION_WINDOW=60

# –––––––––––––––––––––––––––––––––––––––––
# Webhook Telegram (opzionale)
# –––––––––––––––––––––––––––––––––––––––––

OUTLINE_SIGNING_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT=
OUTLINE_API_TOKEN=

# –––––––––––––––––––––––––––––––––––––––––
# Accesso e sicurezza
# –––––––––––––––––––––––––––––––––––––––––

ALLOWED_PRIVATE_IP_ADDRESSES=
WEBHOOK_FAILURE_THRESHOLD=80

# –––––––––––––––––––––––––––––––––––––––––
# Debug
# –––––––––––––––––––––––––––––––––––––––––

ENABLE_UPDATES=true
DEBUG=http
LOG_LEVEL=info
